generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  avatar       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  categories          Category[]
  transactions        Transaction[]
  accounts            Account[]
  budgets             Budget[]
  investmentPositions InvestmentPosition[]
  liabilities         Liability[]
  goals               Goal[]

  @@map("users")
}

model Account {
  id             String      @id @default(cuid())
  userId         String
  name           String
  type           AccountType
  color          String      @default("#6366f1")
  initialBalance Decimal     @default(0) @db.Decimal(12, 2)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions        Transaction[]
  investmentPositions InvestmentPosition[]
  goals               Goal[]

  @@map("accounts")
}

model Category {
  id        String       @id @default(cuid())
  userId    String
  name      String
  type      CategoryType
  color     String       @default("#6366f1")
  icon      String       @default("tag")
  isDefault Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]

  @@map("categories")
}

model Budget {
  id         String   @id @default(cuid())
  userId     String
  categoryId String
  month      Int
  year       Int
  amount     Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, month, year])
  @@map("budgets")
}

model Transaction {
  id             String          @id @default(cuid())
  userId         String
  categoryId     String
  accountId      String?
  type           TransactionType
  amount         Decimal         @db.Decimal(12, 2)
  description    String
  date           DateTime
  notes          String?
  isRecurring    Boolean         @default(false)
  recurrenceType RecurrenceType?
  recurrenceEnd  DateTime?
  parentId       String?
  transferId     String?
  positionId     String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  Category            @relation(fields: [categoryId], references: [id])
  account   Account?            @relation(fields: [accountId], references: [id])
  parent    Transaction?        @relation("RecurringInstances", fields: [parentId], references: [id])
  instances Transaction[]       @relation("RecurringInstances")
  position  InvestmentPosition? @relation(fields: [positionId], references: [id])

  @@map("transactions")
}

model InvestmentPosition {
  id           String                @id @default(cuid())
  userId       String
  accountId    String
  name         String
  ticker       String?
  type         InvestmentPositionType
  quantity     Decimal?              @db.Decimal(15, 6)
  avgPrice     Decimal?              @db.Decimal(12, 2)
  currentValue Decimal               @default(0) @db.Decimal(12, 2)
  notes        String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  account      Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("investment_positions")
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT
  INVESTMENT
  CASH
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum RecurrenceType {
  WEEKLY
  MONTHLY
  YEARLY
}

enum InvestmentPositionType {
  STOCK
  FUND
  FIXED_INCOME
  REAL_ESTATE
  CRYPTO
  OTHER
}

enum LiabilityType {
  LOAN
  FINANCING
  CREDIT_CARD
  OTHER
}

model Liability {
  id             String        @id @default(cuid())
  userId         String
  name           String
  type           LiabilityType
  currentBalance Decimal       @db.Decimal(12, 2)
  installments   Int?
  interestRate   Decimal?      @db.Decimal(5, 4)
  dueDate        DateTime?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("liabilities")
}

model Goal {
  id              String    @id @default(cuid())
  userId          String
  name            String
  targetAmount    Decimal   @db.Decimal(12, 2)
  targetDate      DateTime?
  linkedAccountId String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account? @relation(fields: [linkedAccountId], references: [id], onDelete: SetNull)

  @@map("goals")
}
