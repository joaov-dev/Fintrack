generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  avatar       String?
  mfaSecret    String?
  mfaEnabled   Boolean    @default(false)

  // ── Admin controls ───────────────────────────────────────────────────────────
  status      UserStatus @default(ACTIVE)   // SUSPENDED blocks login
  lastLoginAt DateTime?                     // updated on each successful login

  // ── Preferências financeiras ─────────────────────────────────────────────────
  currency     String   @default("BRL")
  locale       String   @default("pt-BR")
  timezone     String   @default("America/Sao_Paulo")
  dateFormat   String   @default("DD/MM/YYYY")
  closingDay   Int      @default(1)

  // ── Preferências de notificação ──────────────────────────────────────────────
  notifBudget   Boolean @default(true)
  notifGoals    Boolean @default(true)
  notifDue      Boolean @default(true)
  notifInsights Boolean @default(true)
  emailBudget   Boolean @default(false)
  emailGoals    Boolean @default(false)
  emailDue      Boolean @default(false)
  emailInsights Boolean @default(false)

  // ── Assinatura / Billing ─────────────────────────────────────────────────────
  currentPlan        PlanCode            @default(FREE)
  subscriptionStatus SubscriptionStatus?
  subscriptionEndsAt DateTime?
  trialEndsAt        DateTime?
  graceUntil         DateTime?
  billingCustomerId  String?             @unique

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  categories             Category[]
  transactions           Transaction[]
  accounts               Account[]
  budgets                Budget[]
  investmentPositions         InvestmentPosition[]
  investmentMovements         InvestmentMovement[]
  investmentAllocationTargets InvestmentAllocationTarget[]
  liabilities                 Liability[]
  goals                  Goal[]
  creditCards            CreditCard[]
  cardStatements         CardStatement[]
  installmentPlans       InstallmentPlan[]
  insights               Insight[]
  microGoals             MicroGoal[]
  liabilityPayments      LiabilityPayment[]
  sessions               Session[]
  tags                   Tag[]
  transactionAttachments TransactionAttachment[]
  categorizationRules    CategorizationRule[]
  subscriptions          Subscription[]
  usageCounters          UsageCounter[]
  subscriptionEvents     SubscriptionEvent[]
  billingProfile         BillingCustomer?       @relation("UserBillingProfile")
  consentRecords         ConsentRecord[]
  checkoutAttempts       CheckoutAttempt[]
  promotions             UserPromotion[]

  @@map("users")
}

model Session {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  deviceName String?
  ipAddress  String?
  userAgent  String?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime  @default(now())
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id             String      @id @default(cuid())
  userId         String
  name           String
  type           AccountType
  color          String      @default("#6366f1")
  initialBalance Decimal     @default(0) @db.Decimal(12, 2)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions        Transaction[]
  investmentPositions InvestmentPosition[]
  goals               Goal[]
  categorizationRules CategorizationRule[]

  @@map("accounts")
}

model Category {
  id        String       @id @default(cuid())
  userId    String
  name      String
  type      CategoryType
  color     String       @default("#6366f1")
  icon      String       @default("tag")
  isDefault Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions        Transaction[]
  budgets             Budget[]
  categorizationRules CategorizationRule[]

  @@map("categories")
}

model Budget {
  id         String   @id @default(cuid())
  userId     String
  categoryId String
  month      Int
  year       Int
  amount     Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, month, year])
  @@map("budgets")
}

model Transaction {
  id                String          @id @default(cuid())
  userId            String
  categoryId        String
  accountId         String?
  type              TransactionType
  amount            Decimal         @db.Decimal(12, 2)
  description       String
  date              DateTime
  notes             String?
  isRecurring       Boolean         @default(false)
  recurrenceType    RecurrenceType?
  recurrenceEnd     DateTime?
  parentId          String?
  transferId        String?
  positionId        String?
  paymentMethod     PaymentMethod?
  creditCardId      String?
  statementId       String?
  isCardPayment     Boolean         @default(false)
  installmentPlanId String?
  installmentNumber Int?
  splitId           String?
  isPaused          Boolean         @default(false)
  isSkipped         Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category            @relation(fields: [categoryId], references: [id])
  account     Account?            @relation(fields: [accountId], references: [id])
  parent      Transaction?        @relation("RecurringInstances", fields: [parentId], references: [id])
  instances   Transaction[]       @relation("RecurringInstances")
  position    InvestmentPosition? @relation(fields: [positionId], references: [id])
  creditCard  CreditCard?         @relation(fields: [creditCardId], references: [id])
  statement   CardStatement?      @relation(fields: [statementId], references: [id])
  installment InstallmentPlan?    @relation(fields: [installmentPlanId], references: [id])
  tags        Tag[]               @relation("TransactionTags")
  attachments TransactionAttachment[]

  @@map("transactions")
}

model InvestmentPosition {
  id           String                 @id @default(cuid())
  userId       String
  accountId    String
  name         String
  ticker       String?
  type         InvestmentPositionType
  quantity     Decimal?               @db.Decimal(15, 6)
  avgPrice     Decimal?               @db.Decimal(12, 2)
  currentValue Decimal                @default(0) @db.Decimal(12, 2)
  notes        String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  account      Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  movements    InvestmentMovement[]

  @@map("investment_positions")
}

model InvestmentMovement {
  id          String                 @id @default(cuid())
  positionId  String
  userId      String
  type        InvestmentMovementType
  amount      Decimal                @db.Decimal(12, 2)
  quantity    Decimal?               @db.Decimal(15, 6)
  unitPrice   Decimal?               @db.Decimal(12, 6)
  date        DateTime
  description String?
  createdAt   DateTime               @default(now())

  position InvestmentPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)
  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([positionId])
  @@index([userId])
  @@map("investment_movements")
}

model InvestmentAllocationTarget {
  id        String                 @id @default(cuid())
  userId    String
  type      InvestmentPositionType
  targetPct Decimal                @db.Decimal(5, 2)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@map("investment_allocation_targets")
}

model CreditCard {
  id                  String   @id @default(cuid())
  userId              String
  name                String
  brand               String?
  creditLimit         Decimal  @db.Decimal(12, 2)
  statementClosingDay Int
  dueDay              Int
  color               String   @default("#6366f1")
  isArchived          Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  statements       CardStatement[]
  transactions     Transaction[]
  installmentPlans InstallmentPlan[]

  @@map("credit_cards")
}

model CardStatement {
  id          String              @id @default(cuid())
  userId      String
  cardId      String
  periodStart DateTime
  periodEnd   DateTime
  closingDate DateTime
  dueDate     DateTime
  status      CardStatementStatus @default(OPEN)
  totalSpent  Decimal             @default(0) @db.Decimal(12, 2)
  totalPaid   Decimal             @default(0) @db.Decimal(12, 2)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  card         CreditCard    @relation(fields: [cardId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("card_statements")
}

model InstallmentPlan {
  id                String   @id @default(cuid())
  userId            String
  creditCardId      String
  description       String
  totalAmount       Decimal  @db.Decimal(12, 2)
  totalInstallments Int
  installmentAmount Decimal  @db.Decimal(12, 2)
  startDate         DateTime
  createdAt         DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditCard   CreditCard    @relation(fields: [creditCardId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("installment_plans")
}

model Plan {
  id           String    @id @default(cuid())
  code         PlanCode  @unique
  name         String
  description  String?
  isActive     Boolean   @default(true)
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  prices        Price[]
  featureGates  FeatureGate[]
  subscriptions Subscription[]

  @@map("plans")
}

model Price {
  id              String       @id @default(cuid())
  planId          String
  billingCycle    BillingCycle
  amountCents     Int
  currency        String       @default("BRL")
  stripePriceId   String?      @unique
  stripeProductId String?
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  plan          Plan           @relation(fields: [planId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@unique([planId, billingCycle])
  @@map("prices")
}

model BillingCustomer {
  id               String   @id @default(cuid())
  userId           String   @unique
  stripeCustomerId String   @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user          User           @relation("UserBillingProfile", fields: [userId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@map("billing_customers")
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  planId               String
  priceId              String?
  billingCustomerId    String?
  status               SubscriptionStatus
  stripeSubscriptionId String?            @unique
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  trialEndsAt          DateTime?
  graceUntil           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan            Plan             @relation(fields: [planId], references: [id], onDelete: Restrict)
  price           Price?           @relation(fields: [priceId], references: [id], onDelete: SetNull)
  billingCustomer BillingCustomer? @relation(fields: [billingCustomerId], references: [id], onDelete: SetNull)
  events          SubscriptionEvent[]

  @@index([userId, status])
  @@map("subscriptions")
}

model SubscriptionEvent {
  id              String   @id @default(cuid())
  subscriptionId  String?
  userId          String?
  source          String
  eventType       String
  externalEventId String?
  payload         Json?
  createdAt       DateTime @default(now())

  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([source, externalEventId])
  @@index([userId, eventType])
  @@map("subscription_events")
}

model CheckoutAttempt {
  id              String       @id @default(cuid())
  userId          String
  planCode        PlanCode
  billingCycle    BillingCycle
  stripeSessionId String       @unique
  completedAt     DateTime?
  createdAt       DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, completedAt])
  @@index([createdAt, completedAt])
  @@map("checkout_attempts")
}

model UserPromotion {
  id             String    @id @default(cuid())
  userId         String
  stripeCouponId String
  discountPct    Int       @default(10)
  expiresAt      DateTime
  shownAt        DateTime?
  redeemedAt     DateTime?
  sentByAdminId  String
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, redeemedAt, expiresAt])
  @@map("user_promotions")
}

model FeatureGate {
  id            String     @id @default(cuid())
  planId        String
  featureKey    FeatureKey
  enabled       Boolean    @default(false)
  limitPerMonth Int?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featureKey])
  @@map("feature_gates")
}

model UsageCounter {
  id         String     @id @default(cuid())
  userId     String
  featureKey FeatureKey
  year       Int
  month      Int
  usageCount Int        @default(0)
  updatedAt  DateTime   @updatedAt
  createdAt  DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, featureKey, year, month])
  @@map("usage_counters")
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT
  INVESTMENT
  CASH
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum RecurrenceType {
  WEEKLY
  MONTHLY
  YEARLY
  LAST_DAY      // último dia do mês
  BUSINESS_DAYS // primeiro dia útil do mês
}

enum PaymentMethod {
  CASH
  DEBIT
  PIX
  CREDIT_CARD
  TRANSFER
}

enum CardStatementStatus {
  OPEN
  CLOSED
  PAID
  OVERDUE
}

enum InvestmentPositionType {
  STOCK
  FUND
  FIXED_INCOME
  REAL_ESTATE
  CRYPTO
  OTHER
}

enum InvestmentMovementType {
  CONTRIBUTION  // Aporte
  WITHDRAWAL    // Resgate
  DIVIDEND      // Dividendo
  JCP           // Juros sobre Capital Próprio
  INTEREST      // Rendimento / Cupom
  BONUS         // Bonificação
  SPLIT         // Desdobramento
}

enum LiabilityType {
  LOAN
  FINANCING
  CREDIT_CARD
  OTHER
}

model Liability {
  id             String        @id @default(cuid())
  userId         String
  name           String
  type           LiabilityType
  currentBalance Decimal       @db.Decimal(12, 2)
  installments   Int?
  interestRate   Decimal?      @db.Decimal(5, 4)
  dueDate        DateTime?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments LiabilityPayment[]

  @@map("liabilities")
}

model LiabilityPayment {
  id               String   @id @default(cuid())
  userId           String
  liabilityId      String
  installmentsPaid Int?
  grossAmount      Decimal  @db.Decimal(12, 2)
  discountType     String?
  discountValue    Decimal? @db.Decimal(10, 4)
  discountAmount   Decimal  @default(0) @db.Decimal(12, 2)
  paidAmount       Decimal  @db.Decimal(12, 2)
  accountId        String?
  categoryId       String?
  transactionId    String?  @unique
  notes            String?
  paidAt           DateTime
  createdAt        DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  liability Liability @relation(fields: [liabilityId], references: [id], onDelete: Cascade)

  @@map("liability_payments")
}

model Goal {
  id              String    @id @default(cuid())
  userId          String
  name            String
  targetAmount    Decimal   @db.Decimal(12, 2)
  targetDate      DateTime?
  linkedAccountId String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account? @relation(fields: [linkedAccountId], references: [id], onDelete: SetNull)

  @@map("goals")
}

model Insight {
  id           String          @id @default(cuid())
  userId       String
  type         InsightType
  severity     InsightSeverity
  status       InsightStatus   @default(ACTIVE)
  title        String
  message      String
  explanation  String?
  context      Json            @default("{}")
  cta          Json?
  dedupeKey    String
  validFrom    DateTime
  validTo      DateTime
  snoozedUntil DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dedupeKey])
  @@map("insights")
}

model MicroGoal {
  id          String             @id @default(cuid())
  userId      String
  name        String
  scopeType   MicroGoalScopeType
  scopeRefId  String?
  limitAmount Decimal            @db.Decimal(12, 2)
  startDate   DateTime
  endDate     DateTime
  status      MicroGoalStatus    @default(ON_TRACK)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("micro_goals")
}

enum InsightType {
  OUTLIER_SPEND
  NEW_SUBSCRIPTION
  CATEGORY_SPIKE
  DUE_PAYMENT
  BUDGET_AT_RISK
  MICRO_GOAL_AT_RISK
  MICRO_GOAL_BREACHED
  NEGATIVE_CASHFLOW
  HIGH_FIXED_COSTS
  STAGNANT_NET_WORTH
  LOW_EMERGENCY_RESERVE
  HIGH_CREDIT_DEPENDENCY
  HIGH_CC_UTILIZATION
}

enum InsightSeverity {
  CRITICAL
  WARNING
  INFO
}

enum InsightStatus {
  ACTIVE
  DISMISSED
  SNOOZED
  RESOLVED
}

enum MicroGoalStatus {
  ON_TRACK
  AT_RISK
  BREACHED
  COMPLETED
}

enum MicroGoalScopeType {
  CATEGORY
  TOTAL_SPEND
}

enum PlanCode {
  FREE
  PRO
  BUSINESS
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  UNPAID
}

enum FeatureKey {
  BASIC_DASHBOARD
  RECURRING_TRANSACTIONS
  GOALS
  LIABILITIES
  CREDIT_CARDS
  CSV_IMPORT
  RULES_AUTOCATEGORIZATION
  INSIGHTS
  FINANCIAL_HEALTH
  FORECAST
  REPORTS_ADVANCED
  INVESTMENTS_ADVANCED
  INVESTMENT_ALLOCATION
  EXPORT_DATA
  ACCOUNTS_LIMIT
  CREDIT_CARDS_LIMIT
  TRANSACTIONS_MONTHLY_LIMIT
}

// ── LGPD / GDPR Data Governance ───────────────────────────────────────────────

// Every consent is stored as an immutable append-only record.
// Consent state = the most-recent ConsentRecord for (userId, consentType).
// Immutability enforced by trigger from migration 20260305000000_add_lgpd.
model ConsentRecord {
  id          String      @id @default(cuid())
  userId      String
  consentType ConsentType
  version     String      // policy version, e.g. "1.0"
  granted     Boolean     // true = given, false = withdrawn
  ip          String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consentType, createdAt])
  @@map("consent_records")
}

enum ConsentType {
  TERMS_OF_SERVICE    // mandatory — service cannot be used without it
  PRIVACY_POLICY      // mandatory
  MARKETING_EMAIL     // optional — promotional emails
  ANALYTICS           // optional — usage analytics / insights
}

// Soft-delete tombstone: user requested erasure; hard delete runs after 30 days.
// Email kept in suppression list to prevent re-registration during grace period.
model DeletedAccount {
  id          String    @id @default(cuid())
  userId      String    @unique // original users.id (no FK — user row may be gone)
  email       String    @unique // suppression list
  requestedAt DateTime  @default(now())
  scheduledAt DateTime  // requestedAt + 30 days
  completedAt DateTime? // set when retentionService hard-deletes the user

  @@index([scheduledAt])
  @@map("deleted_accounts")
}

// Internal breach tracking for LGPD Art. 48 compliance (72h ANPD notification).
model BreachRecord {
  id               String         @id @default(cuid())
  title            String
  description      String
  severity         BreachSeverity
  affectedCount    Int?
  dataTypes        String[]       // e.g. ["email","transaction_data","ip_address"]
  detectedAt       DateTime
  containedAt      DateTime?
  anpdNotifiedAt   DateTime?
  usersNotifiedAt  DateTime?
  status           BreachStatus   @default(DETECTED)
  notes            String?
  createdBy        String         // userId of admin who created the record
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([status, detectedAt])
  @@map("breach_records")
}

enum BreachSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BreachStatus {
  DETECTED
  INVESTIGATING
  CONTAINED
  NOTIFIED_ANPD
  NOTIFIED_USERS
  CLOSED
}

// ── Auth Security ──────────────────────────────────────────────────────────────

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ip        String?
  success   Boolean
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ip, createdAt])
  @@map("login_attempts")
}

model UsedMfaToken {
  jti       String   @id
  expiresAt DateTime

  @@index([expiresAt])
  @@map("used_mfa_tokens")
}

model UsedTotpCode {
  id     String   @id @default(cuid())
  userId String
  code   String
  usedAt DateTime @default(now())

  @@unique([userId, code])
  @@index([usedAt])
  @@map("used_totp_codes")
}

model AuthEvent {
  id        String   @id @default(cuid())
  userId    String?
  email     String?
  event     String
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([email, createdAt])
  @@index([event, createdAt])
  @@map("auth_events")
  // Immutability enforced by DB trigger: prevent_audit_modification()
  // See migration 20260304000000_add_audit_log
}

// ── Business-operation audit trail ────────────────────────────────────────────
// Append-only; immutability enforced by PostgreSQL trigger (see migration).
// Captures CREATE / UPDATE / DELETE on financial resources.
// Separate from AuthEvent (auth flow) for cleaner querying and IAM separation.

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String   // e.g. TRANSACTION_CREATE, ACCOUNT_UPDATE, GOAL_DELETE
  resource   String   // e.g. 'transaction', 'account', 'goal'
  resourceId String?  // affected record ID (null for bulk operations)
  requestId  String?  // correlates with HTTP access log (X-Request-Id header)
  ip         String?
  userAgent  String?
  before     Json?    // resource state before mutation (UPDATE/DELETE only)
  after      Json?    // resource state after mutation (CREATE/UPDATE only)
  metadata   Json?    // additional context (e.g. { reason: 'user request' })
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([resource, resourceId])
  @@index([action, createdAt])
  @@index([requestId])
  @@map("audit_logs")
  // Immutability enforced by DB trigger: prevent_audit_modification()
}

// ── Tags (many-to-many com Transaction) ───────────────────────────────────────

model Tag {
  id     String @id @default(cuid())
  userId String
  name   String

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[] @relation("TransactionTags")

  @@unique([userId, name])
  @@map("tags")
}

// ── Anexos de Transação (base64 no DB) ────────────────────────────────────────

model TransactionAttachment {
  id            String   @id @default(cuid())
  transactionId String
  userId        String
  filename      String
  mimeType      String
  size          Int
  dataUrl       String   @db.Text
  createdAt     DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transaction_attachments")
}

// ── Regras de Categorização Automática ────────────────────────────────────────

model CategorizationRule {
  id           String   @id @default(cuid())
  userId       String
  name         String
  pattern      String
  matchType    String   @default("CONTAINS")
  categoryId   String
  accountId    String?
  isActive     Boolean  @default(true)
  priority     Int      @default(0)
  appliedCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  account  Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@map("categorization_rules")
}

// ── Admin Panel ───────────────────────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN_READONLY
}

model AdminAccount {
  id           String          @id @default(cuid())
  username     String          @unique
  passwordHash String
  role         AdminRole       @default(SUPER_ADMIN)
  isActive     Boolean         @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  sessions  AdminSession[]
  auditLogs AdminAuditLog[]

  @@map("admin_accounts")
}

model AdminSession {
  id         String       @id @default(cuid())
  adminId    String
  tokenHash  String       @unique
  ipAddress  String?
  userAgent  String?
  expiresAt  DateTime
  createdAt  DateTime     @default(now())
  lastUsedAt DateTime     @default(now())

  admin AdminAccount @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@map("admin_sessions")
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String?
  targetId   String?
  details    Json?
  ip         String?
  createdAt  DateTime @default(now())

  admin AdminAccount @relation(fields: [adminId], references: [id])

  @@index([adminId, createdAt])
  @@index([targetType, targetId])
  @@map("admin_audit_logs")
}
