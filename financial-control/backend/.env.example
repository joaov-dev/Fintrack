# ══════════════════════════════════════════════════════════════════════════════
#  Variáveis de Ambiente — financial-control backend
#
#  Copie este arquivo para .env e preencha os valores.
#  NUNCA faça commit do arquivo .env real (já está no .gitignore).
#
#  Separação de ambientes:
#    Desenvolvimento → NODE_ENV=development  (avisos, logs coloridos, sem HTTPS)
#    Produção        → NODE_ENV=production   (erros genéricos, JSON estruturado,
#                                             chaves obrigatórias, SSL no banco)
# ══════════════════════════════════════════════════════════════════════════════

NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
#
# Desenvolvimento:
DATABASE_URL="postgresql://fintrack:fintrack123@localhost:5432/financial_control"
#
# Banco de dados de TESTES (isolado — apenas para testes de integração):
# Crie o banco: createdb financial_control_test
# Aplique migrations: DATABASE_URL_TEST=<url> npx prisma migrate deploy
DATABASE_URL_TEST="postgresql://fintrack:fintrack123@localhost:5432/financial_control_test"
#
# Produção (SSL obrigatório — nunca conecte sem TLS em produção):
# DATABASE_URL="postgresql://app_user:SENHA_FORTE@db-host:5432/financial_control?ssl=true&sslmode=require"
#
# Privilégios mínimos recomendados:
#   - Crie um role dedicado de leitura/escrita (SELECT/INSERT/UPDATE/DELETE)
#   - NUNCA use o superusuário postgres em produção
#   - Execute: backend/scripts/db-setup-roles.sql
#   - Para backups use um role somente-leitura separado

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Segredo para assinatura de tokens JWT.
# Gere com: openssl rand -hex 64   (128 caracteres hex = 64 bytes)
# OBRIGATÓRIO em produção.
JWT_SECRET="8fa46d7e51dcc4f9dfc2216c03489015fd4cf7019225e9a9e3e0d345a1fa97b73816e4fa8080d981aa824b783dca1a67b87e716f22d6f1542f3860ab8d6038af"

# Custo do bcrypt (padrão: 12 ≈ 400ms/hash).
# Use 8-10 em testes, nunca menos que 10 em produção.
BCRYPT_ROUNDS=12

# ─── Criptografia de campos — MFA ─────────────────────────────────────────────
# Chave AES-256-GCM para secrets TOTP/MFA no banco.
# Gere com: openssl rand -hex 32   (64 hex = 32 bytes)
# OBRIGATÓRIA em produção (sem ela, secrets são guardados em plaintext).
MFA_ENCRYPTION_KEY="de2e249a494c174ff813837163a366b2fed7232149acfb8203bf97905e7561fb"

# ─── Criptografia de campos — Dados sensíveis ─────────────────────────────────
# Chave AES-256-GCM para campos sensíveis no banco (ex: anexos de transações).
# Gere com: openssl rand -hex 32   (64 hex = 32 bytes)
# OBRIGATÓRIA em produção. Se ausente, campos ficam em plaintext (aviso no log).
#
# Rotação de chave:
#   1. Defina DATA_ENCRYPTION_KEY_OLD=<chave antiga>
#   2. Execute script de re-encriptação dos registros existentes
#   3. Remova DATA_ENCRYPTION_KEY_OLD após migração concluída
DATA_ENCRYPTION_KEY=""
# DATA_ENCRYPTION_KEY_OLD=""   # usado apenas durante rotação de chave

# ─── Logging ──────────────────────────────────────────────────────────────────
# Nível mínimo de log: debug | info | warn | error   (padrão: info)
# Produção recomendado: warn (reduz volume; errors são sempre emitidos)
LOG_LEVEL=info

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3333

# Origens permitidas para CORS (vírgula-separado em produção):
# Desenvolvimento:
CORS_ORIGIN="http://localhost:5173"
# Produção (exemplo):
# CORS_ORIGIN="https://app.dominahub.com,https://www.dominahub.com"

# ─── Stripe ───────────────────────────────────────────────────────────────────
#
# 1. Crie uma conta em https://dashboard.stripe.com
#
# 2. STRIPE_SECRET_KEY
#    Dashboard → Developers → API keys → Secret key
#    Teste:      sk_test_...
#    Produção:   sk_live_...
STRIPE_SECRET_KEY=""

# 3. STRIPE_WEBHOOK_SECRET
#    Após configurar o webhook (ver abaixo), copie o Signing secret.
#    Começa com: whsec_...
STRIPE_WEBHOOK_SECRET=""

#
# ── Setup inicial (rode uma vez após preencher STRIPE_SECRET_KEY) ────────────
#
#   npm run db:seed          → cria planos/preços no banco de dados
#   npm run stripe:sync      → cria produtos/preços no Stripe e salva IDs no banco
#
# ── Webhook ──────────────────────────────────────────────────────────────────
#
#   Desenvolvimento local (requer Stripe CLI — https://stripe.com/docs/stripe-cli):
#     npm run stripe:listen
#     → gera um whsec_ temporário; use-o como STRIPE_WEBHOOK_SECRET para testes
#
#   Produção:
#     Dashboard → Developers → Webhooks → Add endpoint
#     URL: https://SEU_DOMINIO/api/billing/webhook/stripe
#     Eventos necessários:
#       customer.subscription.created
#       customer.subscription.updated
#       customer.subscription.deleted
#       checkout.session.completed
#       invoice.payment_failed
#
# ── Customer Portal ──────────────────────────────────────────────────────────
#
#   Para o portal de cobrança funcionar, ative-o no Stripe Dashboard:
#   Dashboard → Billing → Customer portal → Activate portal
#
