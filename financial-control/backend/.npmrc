# Backend workspace — inherits root .npmrc and adds backend-specific settings.

# Explicit registry — workspace-level override for clarity.
registry=https://registry.npmjs.org/

# Fail npm install if any vulnerability at or above this level is found.
# Use 'npm ci' in CI (--ignore-scripts + explicit prisma generate).
# This kicks in during local 'npm install' as a developer safeguard.
audit-level=high
