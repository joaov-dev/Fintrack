# ── Supply Chain Security — npm configuration ────────────────────────────────
#
# These settings apply to all workspaces (root, backend, frontend).
# Overrides are allowed in workspace-level .npmrc files.

# Pin the npm registry to prevent registry-confusion attacks.
# All packages must come from the official registry.
registry=https://registry.npmjs.org/

# Always save exact versions when adding new packages (no ^ or ~ ranges).
# This ensures reproducible installs and explicit upgrade intent.
save-exact=true

# Always maintain a lockfile. Fail if package.json is updated without one.
package-lock=true

# Enforce the Node.js version declared in the "engines" field.
# Prevents running on incompatible runtimes that might behave differently.
engine-strict=true

# Prefer offline cache when available (faster, more deterministic).
prefer-offline=true
